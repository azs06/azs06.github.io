---
import FormattedDate from "./FormattedDate.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { data } = post;
const slug = post.id;
const tags = data.tags ?? [];
const description = data.description ?? "";
const href = `/blog/${slug}/`;
---

<article
  class="blog-post stagger-item group py-4 border-b border-border/50 dark:border-[#3d352d]/50 last:border-b-0"
  data-title={data.title.toLowerCase()}
  data-description={description.toLowerCase()}
  data-tags={tags.map(t => t.toLowerCase()).join(',')}
>
  <div class="flex flex-col gap-1">
    <div class="flex items-center gap-3">
      <span class="text-xs text-muted dark:text-gray-500 font-sans shrink-0">
        <FormattedDate date={data.pubDate} />
      </span>
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5">
          {tags.slice(0, 2).map((tag) => (
            <span class="px-1.5 py-0.5 text-xs text-muted dark:text-gray-400 bg-surface dark:bg-[#2a2520] border border-border/50 dark:border-[#3d352d] rounded font-sans leading-none">
              {tag}
            </span>
          ))}
        </div>
      )}
    </div>
    <a href={href} class="group/link">
      <h3 class="font-medium text-primary dark:text-gray-100 group-hover/link:text-accent transition-colors font-serif">
        {data.title}
      </h3>
      {description && (
        <p class="text-sm text-muted dark:text-gray-400 line-clamp-1 mt-0.5">
          {description}
        </p>
      )}
    </a>
  </div>
</article>
