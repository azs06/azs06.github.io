---
import { getCollection } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import BlogCard from "../../components/BlogCard.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const tagSet = new Set(
  posts.flatMap((post) => post.data.tags ?? []).map((tag) => tag.trim()).filter(Boolean)
);
const tags = Array.from(tagSet).sort((a, b) => a.localeCompare(b));
---

<MainLayout title="Blog - Atiquzzaman Soikat">
  <article class="space-y-12">
    <!-- Header -->
    <section class="section-animate">
      <p class="text-xl text-primary dark:text-gray-200 mb-4 font-semibold">
        Blog
      </p>
      <p class="text-primary/80 dark:text-gray-300 text-lg">
        Thoughts on web development, frontend engineering, and building products.
      </p>
    </section>

    <!-- Search & Filters -->
    <section class="section-animate">
      <form id="blog-search-form" class="flex flex-col gap-4">
        <div class="flex flex-col gap-3 sm:flex-row">
          <input
            id="blog-search"
            name="q"
            type="search"
            placeholder="Search posts..."
            class="flex-1 rounded-lg border border-border dark:border-[#3d352d] bg-paper/50 dark:bg-[#2a2520]/50 px-4 py-2.5 text-sm text-primary dark:text-gray-100 focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/20 font-sans placeholder:text-muted dark:placeholder:text-gray-500"
          />
          <div class="flex gap-2">
            <button
              type="submit"
              class="btn-press rounded-lg bg-accent px-5 py-2.5 text-sm font-medium text-white transition hover:bg-accent/90"
            >
              Search
            </button>
            <button
              id="clear-search"
              type="button"
              class="hidden rounded-lg px-4 py-2.5 text-sm font-medium text-accent hover:underline font-sans"
            >
              Clear
            </button>
          </div>
        </div>
      </form>

      {tags.length > 0 && (
        <details id="tags-details" class="mt-4 overflow-hidden rounded-lg border border-border dark:border-[#3d352d] bg-paper/50 dark:bg-[#2a2520]/50">
          <summary class="flex cursor-pointer items-center justify-between gap-2 px-4 py-3 text-sm font-medium text-primary dark:text-gray-100 font-sans">
            <span>Browse by tags</span>
            <span id="tags-summary" class="text-xs font-medium uppercase tracking-wide text-muted dark:text-gray-400">
              {tags.length} topics
            </span>
          </summary>
          <div class="border-t border-border/50 dark:border-[#3d352d]/50 px-4 py-4">
            <div id="tags-container" class="flex flex-wrap gap-2">
              {tags.map((tag) => (
                <button
                  type="button"
                  class="tag-button pill-bounce px-2.5 py-1 text-xs font-medium text-muted dark:text-gray-400 bg-surface dark:bg-[#2a2520] border border-border/50 dark:border-[#3d352d] rounded font-sans transition"
                  data-tag={tag.toLowerCase()}
                >
                  {tag}
                </button>
              ))}
            </div>
          </div>
        </details>
      )}
      <p id="filter-status" class="mt-3 hidden text-sm text-muted dark:text-gray-400 font-sans"></p>
    </section>

    <!-- No results -->
    <div id="no-results" class="hidden rounded-lg border border-dashed border-border dark:border-[#3d352d] p-12 text-center bg-paper/50 dark:bg-[#2a2520]/50">
      <p class="font-medium text-primary dark:text-gray-100">No posts found</p>
      <p class="mt-2 text-sm text-muted dark:text-gray-400">
        Try a different search term or{" "}
        <button id="clear-from-no-results" type="button" class="text-accent hover:underline">browse all posts</button>.
      </p>
    </div>

    <!-- Posts List -->
    <section class="section-animate">
      <div id="posts-grid" class="flex flex-col">
        {posts.map((post) => (
          <BlogCard post={post} />
        ))}
      </div>
    </section>
  </article>

  <script>
    // Client-side filtering for blog posts
    function initBlogFilter() {
      const searchInput = document.getElementById('blog-search') as HTMLInputElement;
      const searchForm = document.getElementById('blog-search-form') as HTMLFormElement;
      const clearButton = document.getElementById('clear-search') as HTMLButtonElement;
      const clearFromNoResults = document.getElementById('clear-from-no-results') as HTMLButtonElement;
      const filterStatus = document.getElementById('filter-status') as HTMLParagraphElement;
      const noResults = document.getElementById('no-results') as HTMLDivElement;
      const postsGrid = document.getElementById('posts-grid') as HTMLDivElement;
      const tagButtons = document.querySelectorAll('.tag-button') as NodeListOf<HTMLButtonElement>;
      const tagsDetails = document.getElementById('tags-details') as HTMLDetailsElement;
      const tagsSummary = document.getElementById('tags-summary') as HTMLSpanElement;

      function filterPosts(query: string) {
        const normalizedQuery = query.trim().toLowerCase();
        const posts = document.querySelectorAll('.blog-post') as NodeListOf<HTMLElement>;
        let visibleCount = 0;

        posts.forEach(post => {
          if (!normalizedQuery) {
            post.style.display = '';
            visibleCount++;
            return;
          }

          const title = post.dataset.title || '';
          const description = post.dataset.description || '';
          const tags = post.dataset.tags || '';
          const searchText = `${title} ${description} ${tags}`;

          if (searchText.includes(normalizedQuery)) {
            post.style.display = '';
            visibleCount++;
          } else {
            post.style.display = 'none';
          }
        });

        searchInput.value = query;

        if (normalizedQuery) {
          clearButton.classList.remove('hidden');
          filterStatus.classList.remove('hidden');
          filterStatus.innerHTML = `Showing <span class="font-semibold">${visibleCount}</span> post${visibleCount === 1 ? '' : 's'} matching <span class="font-semibold">"${query}"</span>`;

          const matchingTag = Array.from(tagButtons).find(btn => btn.dataset.tag === normalizedQuery);
          if (matchingTag) {
            tagsDetails.open = true;
            tagsSummary.textContent = `Filtering ${query}`;
          }
        } else {
          clearButton.classList.add('hidden');
          filterStatus.classList.add('hidden');
          tagsSummary.textContent = `${tagButtons.length} topics`;
        }

        // Update tag button styles
        tagButtons.forEach(btn => {
          if (btn.dataset.tag === normalizedQuery) {
            btn.className = 'tag-button pill-bounce px-2.5 py-1 text-xs font-medium text-white bg-accent border border-accent rounded font-sans transition';
          } else {
            btn.className = 'tag-button pill-bounce px-2.5 py-1 text-xs font-medium text-muted dark:text-gray-400 bg-surface dark:bg-[#2a2520] border border-border/50 dark:border-[#3d352d] rounded font-sans transition';
          }
        });

        if (visibleCount === 0 && normalizedQuery) {
          noResults.classList.remove('hidden');
          postsGrid.classList.add('hidden');
        } else {
          noResults.classList.add('hidden');
          postsGrid.classList.remove('hidden');
        }

        const url = new URL(window.location.href);
        if (normalizedQuery) {
          url.searchParams.set('q', query);
        } else {
          url.searchParams.delete('q');
        }
        window.history.pushState({}, '', url);
      }

      searchForm.addEventListener('submit', (e) => {
        e.preventDefault();
        filterPosts(searchInput.value);
      });

      tagButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          const tag = btn.textContent?.trim() || '';
          filterPosts(tag);
        });
      });

      const clearFilter = () => {
        searchInput.value = '';
        filterPosts('');
      };

      clearButton.addEventListener('click', clearFilter);
      clearFromNoResults.addEventListener('click', clearFilter);

      const urlParams = new URLSearchParams(window.location.search);
      const initialQuery = urlParams.get('q') || '';
      if (initialQuery) {
        filterPosts(initialQuery);
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initBlogFilter);
    } else {
      initBlogFilter();
    }
  </script>
</MainLayout>
