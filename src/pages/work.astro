    imageUrl:
      "https://res.cloudinary.com/theazs/image/upload/w_1000,ar_16:9,c_fill,g_auto,e_sharpen/v1737232766/personal-website/zabfcuvtplaxvl61kens.png",
    projectUrl: "https://www.skipperhospitality.com/",
